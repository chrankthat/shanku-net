<!doctype html>
<html lang="en">
<head>
<!-- ============================================================
     GENERATED FILE - DO NOT HAND-EDIT.
     Rendered by resume/build.py from resume/resume.json.
     Edit resume.json (or the templates) and rerun build.py.
     ============================================================ -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5">
<title>{{ identity.name }} - Resume</title>
<meta name="description" content="{{ identity.oneliner }}">
<meta name="robots" content="noindex, nofollow">
<meta name="x-resume-source-sha256" content="{{ source_sha }}">
<meta property="og:title" content="{{ identity.name }} - Resume">
<meta property="og:description" content="{{ identity.oneliner }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ meta.canonical_url }}">
<meta property="og:image" content="https://shanku.net/images/og-image.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ identity.name }} - AI Builder, FSI Strategist, Storyteller">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ identity.name }} - Resume">
<meta name="twitter:description" content="{{ identity.oneliner }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="icon" href="/images/CJS-logo-round.png" type="image/png">
<link rel="apple-touch-icon" href="/images/CJS-logo-round.png">
<link rel="stylesheet" href="../css/tokens.css">
<link rel="stylesheet" href="resume.css">
<script src="resume.js" defer></script>
</head>
{%- macro contact_block() %}
  <div class="contact">
    <span class="cap">Contact</span>
    <a href="mailto:{{ contact.email }}">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      <span class="c-val">{{ contact.email }}</span>
    </a>
    <a href="tel:{{ tel_href }}">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.6a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.5-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.6 2.6.7a2 2 0 0 1 1.7 2Z"/></svg>
      <span class="c-val">+1 {{ contact.phone }}</span>
    </a>
    <a href="{{ contact.linkedin }}" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6Z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      <span class="c-val">{{ contact.linkedin_display }}</span>
    </a>
  </div>
{%- endmacro %}
<body>

<a href="#main" class="skip-link">Skip to content</a>

<!-- ============================================================
     MOBILE - full identity block (in normal flow, scrolls away)
     ============================================================ -->
<div class="m-identity">
  <div class="avatar" style="width:76px;height:76px;">
    <span class="fallback">{{ identity.initials }}</span>
    <img src="{{ identity.avatar }}" alt="{{ identity.name }}" onerror="this.style.display='none'">
  </div>
  <p class="ident-name" role="heading" aria-level="1">{{ identity.name }}</p>
  <p class="motto">{{ identity.motto }}</p>
  <p class="oneliner">{{ identity.oneliner }}</p>
  <div class="credentials">
{%- for cred in credentials %}
    <div class="row"><span class="label">{{ cred.label }}</span><span class="value">{{ cred.value }}</span></div>
{%- endfor %}
  </div>
  <a class="btn-download" href="/resume/{{ meta.pdf_filename }}" target="_blank" rel="noopener" aria-label="Open resume PDF in a new tab">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 11l5 5 5-5"/><path d="M4 21h16"/></svg>
    Download resume (PDF)
  </a>
{{ contact_block() }}
</div>

<!-- ============================================================
     MOBILE - slim sticky bar. Sticks once m-identity scrolls up.
     ============================================================ -->
<div class="m-bar">
  <div class="avatar" style="width:28px;height:28px;">
    <span class="fallback">{{ identity.initials }}</span>
    <img src="{{ identity.avatar }}" alt="" onerror="this.style.display='none'">
  </div>
  <span class="name">{{ identity.name }}</span>
  <span class="cred">{{ identity.mbar_cred }}</span>
</div>

<div class="dossier">

  <!-- ============================================================
       DESKTOP - persistent sticky rail (~30% width at lg / 1024px+)
       ============================================================ -->
  <aside class="rail" aria-label="Identity and credentials">
    <div class="avatar">
      <span class="fallback">{{ identity.initials }}</span>
      <img src="{{ identity.avatar }}" alt="{{ identity.name }}" onerror="this.style.display='none'">
    </div>
    <h1>{{ identity.name }}</h1>
    <p class="motto">{{ identity.motto }}</p>
    <p class="oneliner">{{ identity.oneliner }}</p>

    <div class="credentials">
{%- for cred in credentials %}
      <div class="row"><span class="label">{{ cred.label }}</span><span class="value">{{ cred.value }}</span></div>
{%- endfor %}
    </div>

    <a class="btn-download" href="/resume/{{ meta.pdf_filename }}" target="_blank" rel="noopener" aria-label="Open resume PDF in a new tab">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 11l5 5 5-5"/><path d="M4 21h16"/></svg>
      Download resume (PDF)
    </a>
{{ contact_block() }}
{%- if ship_log.enabled and ship_log.entries %}

    <!-- Rail footer: sparkline mirrors the full log in #timeline below.
         Same source data, compressed. Not decoration. -->
    <div class="sparkline-wrap">
      <div class="sparkline-cap"><span>Ship log</span><b>{{ ship_log.entries | length }} ships · {{ ship_log.entries[0].date[:4] }}</b></div>
      <div class="sparkline">
        <svg viewBox="0 0 200 34" preserveAspectRatio="none" aria-hidden="true">
          <polyline class="spark-path" points="{{ sparkline_points }}"/>
          <circle class="spark-dot" cx="200" cy="4" r="2.2"/>
        </svg>
      </div>
      <div class="sparkline-foot"><span>{{ ship_log.entries[-1].date[:4] }}</span><span>last: {{ ship_log.entries[0].date }}</span></div>
    </div>
{%- endif %}
  </aside>

  <!-- ============================================================
       MAIN - AI Portfolio, Storytelling, Career, Skills, Credentials, Ship log
       ============================================================ -->
  <main id="main">

    <!-- ---------------- AI Portfolio ---------------- -->
    <section id="ventures" aria-label="AI Portfolio">
      <div class="section-head">
        <h2 class="section-title">AI Portfolio</h2>
        <span class="hint">{{ ventures | length }} entries · tap to expand</span>
      </div>

      <div class="ledger">
{%- for v in ventures %}

        <details class="venture">
          <summary>
            <span class="marker" aria-hidden="true">+</span>
            <span class="venture-main">
              <span class="venture-name">{{ v.name }}</span>
              <span class="venture-tag">{{ v.tag }}</span>
            </span>
{%- if v.signal.type == 'count' and v.signal.display == 'ledger' %}
            <span class="venture-meta is-total"><small>{{ v.signal.caption }}</small>{{ v.signal.value }}</span>
{%- elif v.signal.type == 'count' %}
            <span class="venture-meta">{{ v.signal.value }} {{ v.signal.caption }}</span>
{%- else %}
            <span class="venture-meta">{{ v.signal.value }}</span>
{%- endif %}
          </summary>
          <div class="venture-body">
            <p>{{ v.body }}</p>
{%- if v.field.kind == 'link' %}
            <a class="venture-field" href="{{ v.field.href }}" target="_blank" rel="noopener">{{ v.field.label }}</a>
{%- else %}
            <span class="venture-field">{{ v.field.label }}</span>
{%- endif %}
{%- if v.exemplars %}

            <div class="exemplars">
{%- for ex in v.exemplars %}

              <div class="exemplar">
                <div class="facade" tabindex="0" role="button"
                     aria-label="Play {{ ex.name }} demo video"
                     data-embed="{{ ex.embed }}">
                  <span class="mono-mark">{{ ex.mark }}</span>
                  <span class="play"><span><svg viewBox="0 0 10 10"><polygon points="0,0 10,5 0,10"/></svg></span></span>
{%- if ex.duration %}
                  <span class="dur">{{ ex.duration }}</span>
{%- endif %}
                </div>
                <div class="exemplar-body">
                  <div class="head">
                    <span class="exemplar-name">{{ ex.name }}</span>
                    <a class="exemplar-url" href="{{ ex.href }}" target="_blank" rel="noopener">{{ ex.label }}</a>
                  </div>
                  <p>{{ ex.desc }}</p>
                </div>
              </div>
{%- endfor %}

            </div>
{%- endif %}
{%- if v.thesis %}

            <div class="thesis">
              <p>{{ v.thesis }}</p>
            </div>
{%- endif %}
          </div>
        </details>
{%- endfor %}

      </div>
    </section>

    <!-- ---------------- Storytelling (differentiator, before Career) ---------------- -->
    <section id="storytelling" aria-label="Storytelling and community">
      <div class="section-head">
        <h2 class="section-title">Storytelling &amp; Community</h2>
        <span class="hint">on and off the stage</span>
      </div>

      <div class="story-block">
        <div class="story-head">
          <span class="story-name">{{ storytelling.moth.name }}</span>
          <span class="story-kicker">{{ storytelling.moth.kicker }}</span>
        </div>
        <div class="story-wins">
{%- for w in storytelling.moth.wins %}
          <span class="story-win">
            <span class="w-event">{{ w.event }}</span>
            <span class="w-title">"{{ w.title }}"</span>
            <span class="w-foot">
              <span class="w-meta">{{ w.date }}</span>
              <a class="w-yt" href="{{ w.youtube }}" target="_blank" rel="noopener" aria-label="Watch &quot;{{ w.title }}&quot; on YouTube">
                <svg viewBox="0 0 28 20" aria-hidden="true"><rect class="yt-bg" width="28" height="20" rx="5"/><polygon points="11,6 20,10 11,14" fill="#0D1F1C"/></svg>
              </a>
            </span>
          </span>
{%- endfor %}
        </div>
        <p>{{ storytelling.moth.blurb }}</p>
      </div>

      <div class="story-block">
        <div class="story-head">
          <span class="story-name">{{ storytelling.speaking.name }}</span>
          <span class="story-kicker">{{ storytelling.speaking.kicker }}</span>
        </div>

        <div class="stat-row">
{%- for s in storytelling.speaking.stats %}
          <div class="stat-pair"><span class="cap">{{ s.cap }}</span><span class="num">{{ s.num }}</span></div>
{%- endfor %}
        </div>

        <div class="skill-group" style="margin-bottom:0;">
          <span class="cat">All engagements</span>
          <div class="skill-list">
{%- for e in storytelling.speaking.engagements %}
            <span>{{ e.label }}{% if e.play %}<span class="mini-play" aria-hidden="true"><svg viewBox="0 0 10 10"><polygon points="0,0 10,5 0,10"/></svg></span>{% endif %}</span>
{%- endfor %}
          </div>
        </div>
      </div>

      <p class="mantra">{{ storytelling.mantra }}</p>
    </section>

    <!-- ---------------- Career (disclosure ledger) ---------------- -->
    <section id="career" aria-label="Career history">
      <div class="section-head">
        <h2 class="section-title">Career</h2>
        <span class="hint">{{ career.hint }}</span>
      </div>

      <div class="career-ledger">
{%- for row in career.rows %}
        <details class="career-item">
          <summary>
            <span class="marker" aria-hidden="true">+</span>
            <div>
              <div class="career-co">{{ row.company }}{% if row.company_note %} <span class="career-conote">{{ row.company_note }}</span>{% endif %}</div>
              <div class="career-role">{{ row.role }} · {{ row.location }}</div>
            </div>
            <div class="career-dates">{{ row.dates }}</div>
          </summary>
          <div class="career-body">
            <ul class="career-bullets">
{%- for b in row.bullets %}
              <li>{{ b }}</li>
{%- endfor %}
            </ul>
{%- if row.awards %}
            <div class="career-awards"><b>Awards:</b> {{ row.awards | join(' · ') }}</div>
{%- endif %}
          </div>
        </details>
{%- endfor %}
      </div>
    </section>

    <!-- ---------------- Skills (Top-5 strip + chip groups) ---------------- -->
    <section id="skills" aria-label="Skills and stack">
      <div class="section-head">
        <h2 class="section-title">Skills</h2>
        <span class="hint">top 5 · then full stack</span>
      </div>

      <div class="sig-skills">
        <span class="cat">Signature strengths</span>
{%- for s in signature_strengths %}
        <div class="sig-row">
          <span class="sig-name">{{ s.name }}</span>
          <span class="sig-meter">
{%- for i in range(1, 6) -%}
{%- if i <= s.score | int %}<i class="on"></i>
{%- elif (s.score - (s.score | int)) >= 0.5 and i == (s.score | int) + 1 %}<i class="half"></i>
{%- else %}<i></i>
{%- endif -%}
{%- endfor %}
</span>
          <span class="sig-score">{{ "%.1f" | format(s.score) }}</span>
        </div>
{%- endfor %}
      </div>
{%- for group in skills %}

      <div class="skill-group">
        <span class="cat">{{ group.category }}</span>
        <div class="skill-list">
          {% for item in group['items'] %}<span>{{ item }}</span>{% endfor %}
        </div>
      </div>
{%- endfor %}
    </section>

    <!-- ---------------- Credentials (education + certs + principles) ---------------- -->
    <section id="credentials" aria-label="Education and certifications">
      <div class="section-head">
        <h2 class="section-title">Credentials</h2>
        <span class="hint">degree · {{ cert_total }} certifications</span>
      </div>
{%- for edu in education %}

      <div class="edu-row">
        <div>
          <div class="edu-co">{{ edu.school }}</div>
          <div class="edu-deg">{{ edu.degree }}</div>
        </div>
        <div class="edu-loc">{{ edu.location }}</div>
      </div>
{%- endfor %}

      <details class="certs">
        <summary>
          <span class="marker" aria-hidden="true">+</span>
          <span class="certs-title">Certifications</span>
          <span class="certs-count">{{ cert_total }} · {{ cert_issuers }} issuers</span>
        </summary>
        <div class="certs-body">
{%- for group in certifications %}
          <div class="cert-group">
            <span class="issuer">{{ group.issuer }} · {{ group['items'] | length }}</span>
            <div class="cert-list">
              {% for item in group['items'] %}<span>{{ item }}</span>{% endfor %}
            </div>
          </div>
{%- endfor %}
        </div>
      </details>
{%- if principles %}

      <details class="certs">
        <summary>
          <span class="marker" aria-hidden="true">+</span>
          <span class="certs-title">Principles &amp; influences</span>
          <span class="certs-count">values · books · quotes</span>
        </summary>
        <div class="principles-body">
          <div class="prin-group">
            <span class="plabel">Core values</span>
            <div class="prin-values">{{ principles['values'] | join(' · ') }}</div>
          </div>
          <div class="prin-group">
            <span class="plabel">Influential books</span>
            <ul class="prin-books">
{%- for book in principles.books %}
              <li><b>{{ book.title }}</b> <span>{{ book.author }}</span></li>
{%- endfor %}
            </ul>
          </div>
          <div class="prin-group">
            <span class="plabel">Words I keep close</span>
{%- for q in principles.quotes %}
            <p class="prin-quote">{{ q.text }}<cite>{{ q.cite }}</cite></p>
{%- endfor %}
          </div>
        </div>
      </details>
{%- endif %}
    </section>
{%- if ship_log.enabled and ship_log.entries %}

    <!-- ---------------- Shipping log (full) ---------------- -->
    <section id="timeline" aria-label="Shipping timeline">
      <div class="section-head">
        <h2 class="section-title">Shipping log</h2>
        <span class="hint">reverse-chronological · self-updating</span>
      </div>

      <div class="timeline">
{%- for entry in ship_log.entries %}
        <div class="t-row"><div class="t-date">{{ entry.date }}</div><div class="t-body"><span class="t-tag">{{ entry.venture }}</span>{{ entry.text }}</div></div>
{%- endfor %}
      </div>
    </section>
{%- endif %}

  </main>
</div>

<footer class="page-footer">
  shanku.net/resume &middot; renders from resume.json &middot; last updated {{ meta.last_updated }}
</footer>

</body>
</html>
